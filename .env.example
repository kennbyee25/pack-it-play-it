# Telemetry sink (MVP 5). Copy to .env.local (git-ignored) and fill in.
# Without these, the app runs with a NoopSink — no traces are collected.
#
# The anon key is the *publishable* Supabase key; it is designed to live in the
# client bundle. RLS (insert-only for anon) is what protects the traces table.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-ANON-KEY
